# Gemini / Google Cloud configuration.
# Copy this file to .env and fill in project-specific values.

MASS_ADK_MODEL=gemini-3.5-flash
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_STORAGE_BUCKET=your-gcs-bucket

# Agent Runtime / Cloud Run deployment region. This is separate from the Gemini
# model-serving location above; `global` is useful for Gemini model lookup but is
# not necessarily a valid deployment region.
MASS_ADK_DEPLOY_REGION=us-central1

# Optional paths. The integrated engine defaults to bundled synthetic sample data
# under ./sample_data so reviewers do not need the original MASS dataset.
# MASS_ADK_DATASET_ROOT=/absolute/path/to/MASS_adk/sample_data/ih_smoke
# MASS_ADK_SP500_DATA_ROOT=/absolute/path/to/MASS_adk/sample_data/sp500_smoke

MASS_ADK_DEFAULT_STOCK_POOL=sp500
MASS_ADK_DEFAULT_EVAL_LABEL=10

# Expensive live MASS runs are disabled by default. Cached benchmark summaries
# are used for the competition demo path.
MASS_ADK_ENABLE_LIVE_RUNS=false

# Integrated MASS engine artifact backend. Local is the default and writes
# manifests/progress under ./artifacts. Use gcs after bucket access is configured.
MASS_ADK_ARTIFACT_BACKEND=local
MASS_ADK_LOCAL_ARTIFACT_ROOT=./artifacts
MASS_ADK_GCS_PREFIX=mass-adk

# Optional live integrated MASS engine execution. These are required only if you
# run `python -m mass_engine.runner --smoke --execute`. Dry-run mode and ADK
# analysis do not need them.
MASS_MODEL_NAME=your-openai-compatible-model
MASS_MODEL_SERVER=https://your-openai-compatible-endpoint.example.com/v1
MASS_API_KEY=your-openai-compatible-api-key
